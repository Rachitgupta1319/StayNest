<%layout("layouts/boilerplate")%>

<div class="new-listing-page">
  <div class="new-listing-card">
    <h3>Create a New Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
      <div class="form-grid">
        <div class="form-group">
          <label for="title" class="form-label">Title</label>
          <input name="listing[title]" placeholder="Enter title" type="text" required class="form-control" />
          <div class="invalid-feedback">Title is required.</div>
          <div class="valid-feedback">Title is valid.</div>
        </div>

        <div class="form-group">
          <label for="price" class="form-label">Price</label>
          <input name="listing[price]" placeholder="Enter price" type="text" required class="form-control" />
          <div class="invalid-feedback">Price is required.</div>
          <div class="valid-feedback">Price is valid.</div>
        </div>
      </div>

      <div class="form-group">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" placeholder="Enter description" required class="form-control"></textarea>
        <div class="invalid-feedback">Description is required.</div>
        <div class="valid-feedback">Description is valid.</div>
      </div>

      <!-- <div class="form-grid">
        <div class="form-group">
          <label for="image" class="form-label">Image URL</label>
          <input name="listing[image]" placeholder="Enter image URL or link" type="text" />
        </div> -->
      <div class="form-grid">
        <div class="form-group">
          <label for="image" class="form-label">Upload Image</label>
          <input name="listing[image]" type="file" class="form-control" />
        </div>

        <div class="form-group">
          <label for="country" class="form-label">Country</label>
          <input name="listing[country]" placeholder="Enter country" type="text" required class="form-control" />
          <div class="invalid-feedback">Country is required.</div>
          <div class="valid-feedback">Country is valid.</div>
        </div>
      </div>

      <div class="form-group">
        <label for="location" class="form-label">Location</label>
        <input name="listing[location]" placeholder="Enter location" type="text" required class="form-control" />
        <div class="invalid-feedback">Location is required.</div>
        <div class="valid-feedback">Location is valid.</div>
      </div>

      <button class="btn btn-primary mt-3">Add Listing</button>
    </form>
  </div>
</div>