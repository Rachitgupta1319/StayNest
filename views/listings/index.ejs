<%layout("layouts/boilerplate")%>
<div class="listings-page">
  <div class="page-header">
    <h3><%= searchQuery ? `Search results for "${searchQuery}"` : 'All Listings' %></h3>
  </div>

  <% if (allListings.length === 0) { %>
    <div class="alert alert-warning">No listings found. Try a different keyword.</div>
  <% } else { %>
    <div class="card-grid">
      <% for(let listing of allListings) { %>
        <a class="listing-card" href="/listings/<%= listing._id %>">
          <img src="<%= listing.image.url %>" alt="<%= listing.title %>" />
          <div class="card-body">
            <h5><%= listing.title %></h5>
            <p class="price">₹<%= listing.price %> / night</p>
          </div>
        </a>
      <% } %>
    </div>
  <% } %>
</div>